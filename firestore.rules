rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // DANIŞMAN: aşağıdaki e-postayı kendi giriş e-postanla değiştir
    function danisman() {
      return request.auth != null
        && request.auth.token.email == "DANISMAN-EPOSTANI-BURAYA-YAZ@gmail.com";
    }

    // Eşleştirme kodları
    match /kodlar/{kod} {
      allow read: if request.auth != null;
      allow create, delete: if danisman();
      // Danışman her şeyi güncelleyebilir; öğrenci yalnızca boş bir kodu
      // kendi uid'siyle sahiplenebilir (adı değiştiremez)
      allow update: if danisman() || (
        request.auth != null
        && resource.data.uid == null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.ad == resource.data.ad
      );
    }

    // Öğrenci verileri: danışman hepsini, öğrenci yalnızca kendisininkini
    match /ogrenciler/{uid} {
      allow read, write: if danisman() || (request.auth != null && request.auth.uid == uid);
    }
    match /ogrenciler/{uid}/{belge=**} {
      allow read, write: if danisman() || (request.auth != null && request.auth.uid == uid);
    }
  }
}
